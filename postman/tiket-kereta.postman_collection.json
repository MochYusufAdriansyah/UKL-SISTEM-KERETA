    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Penumpang",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{penumpangUsername}}\",\n  \"password\": \"{{penumpangPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Request succeeded\", function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data && data.id !== undefined) pm.collectionVariables.set('userId', String(data.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Penumpang",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{penumpangUsername}}\",\n  \"password\": \"{{penumpangPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login succeeded\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data && data.token) pm.collectionVariables.set('penumpangToken', data.token);",
                  "if (data && data.user && data.user.id !== undefined) pm.collectionVariables.set('userId', String(data.user.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Requires an existing admin account. Public registration does not create admin users."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login succeeded\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data && data.token) pm.collectionVariables.set('adminToken', data.token);",
                  "if (data && data.user && data.user.id !== undefined) pm.collectionVariables.set('adminUserId', String(data.user.id));"
                ]
              }
            }
          ]
        }
      ]
    },
